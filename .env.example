# =============================================================================
# Trading bot environment — copy to `.env` and fill in. NEVER commit `.env`.
# On the droplet: owned by the `tradingbot` user, permissions 600 (Section 22.3).
# Config precedence (Section 12.1): base.yaml < {mode}.yaml < env vars (BOT_*) < CLI.
# =============================================================================

# --- Runtime mode ------------------------------------------------------------
# One of: paper | live | backtest. Overrides config `mode:`.
BOT_MODE=paper

# --- Database (TimescaleDB) ---------------------------------------------------
# Local dev: the tradingbot_dev database created in docs/dev-setup-ubuntu.md.
# Use the password you set for the `tradingbot` role.
DATABASE_URL=postgresql://tradingbot:CHANGEME@localhost:5432/tradingbot_dev

# --- Exchange: Bybit (trade-only permissions, NEVER withdraw — Section 4.4) ---
# Phase 1-5 use testnet keys. Phase 6+ uses live keys, IP-restricted to the host.
BYBIT_API_KEY=
BYBIT_API_SECRET=
# true = Bybit testnet, false = live exchange. Mirrors config exchange.testnet.
BYBIT_TESTNET=true

# --- Telegram (Section 19.2) --------------------------------------------------
# Created via @BotFather. Token is the bot's password — never commit.
TELEGRAM_BOT_TOKEN=
# Your numeric chat id (from getUpdates).
TELEGRAM_CHAT_ID=
# Comma-separated chat ids allowed to issue commands (HARD CONSTRAINT 19.2.2).
TELEGRAM_AUTHORIZED_CHAT_IDS=
# Optional 2FA for /flatten and /shutdown. Set true to require a TOTP code.
TELEGRAM_REQUIRE_TOTP=false
TELEGRAM_TOTP_SECRET=

# --- Optional macro data (Section 8.4) ---------------------------------------
# FRED API key for macro indicators. Optional; bot uses cached values if absent.
FRED_API_KEY=

# --- Backups: DigitalOcean Spaces, S3-compatible (Section 22.6) ---------------
# Needed from Phase 8. Leave blank until then.
DO_SPACES_BUCKET=
DO_SPACES_REGION=sgp1
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_KEY=
DO_SPACES_SECRET=
